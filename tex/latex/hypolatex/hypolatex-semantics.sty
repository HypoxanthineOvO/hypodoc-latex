\makeatletter
\newif\ifHypo@ingroupedqa
\Hypo@ingroupedqafalse
\@ifundefined{HypoIconTitleIndent}{%
  \newlength{\HypoIconTitleIndent}%
  \setlength{\HypoIconTitleIndent}{1.80em}%
}{}%

\NewDocumentCommand{\Hypo@ResolveTitle}{m m}{%
  \ifstrempty{#1}{#2}{#1}%
}

\NewDocumentCommand{\Hypo@ResolvePrefixedTitle}{m m}{%
  \ifstrempty{#1}{#2}{#2: #1}%
}

\NewDocumentCommand{\HypoBoxTitle}{m m}{%
  \HypoIconTitle{#1}{#2}%
}

\tcbset{
  hypobox/base/.style={
    breakable,
    enhanced,
    arc=1mm,
    boxrule=0.5pt,
    left=8pt,
    right=8pt,
    top=7pt,
    bottom=7pt,
    before skip=7pt,
    after skip=7pt
  },
  hypobox/subtle/.style={
    boxrule=0.45pt,
    leftrule=2pt
  },
  hypobox/marked/.style={
    boxrule=0.6pt,
    leftrule=2.5pt
  },
  hypobox/card/.style={
    boxrule=0.75pt,
    leftrule=3pt,
    left=9pt,
    right=9pt,
    top=8pt,
    bottom=8pt
  },
  hypobox/answer/.style={
    boxrule=0.5pt,
    leftrule=2pt
  },
  hypobox/rubric/.style={
    arc=0.8mm,
    boxrule=0.7pt
  },
  hypobox/question-plain/.style={
    breakable,
    enhanced,
    arc=0.8mm,
    boxrule=0.35pt,
    leftrule=2pt,
    left=8pt,
    right=8pt,
    top=5pt,
    bottom=6pt,
    toptitle=3pt,
    bottomtitle=3pt,
    before skip=5pt,
    after skip=7pt
  },
  hypobox/qa/.style={
    boxrule=0.7pt,
    leftrule=3pt,
    left=10pt,
    right=10pt,
    top=9pt,
    bottom=9pt
  }
}

\NewDocumentCommand{\HypoBox}{m m m m +m}{%
  \begin{tcolorbox}[
    hypobox/base,
    breakable,
    colback=#1Back,
    colframe=#1Frame,
    colbacktitle=#1TitleBack,
    coltitle=#1TitleText,
    fonttitle=\HypoSemanticTitleFont,
    title={\HypoBoxTitle{#2}{#3}},
    #4
  ]
  #5%
  \end{tcolorbox}%
}

\NewDocumentCommand{\HypoQASection}{m m m +m}{%
  \par\medskip
  \noindent{\HypoSemanticTitleFont\color{#1Frame}\HypoBoxTitle{#2}{#3}\par}
  \vspace{2pt}%
  {\color{#1Frame}\hrule height 0.35pt}%
  \vspace{5pt}%
  {\leftskip=\HypoIconTitleIndent\relax #4\par}%
}

\NewDocumentCommand{\HypoTextQASection}{m m m +m}{%
  \par\vspace{2pt}%
  \noindent{\HypoSemanticTitleFont\color{#1Frame}\HypoBoxTitle{#2}{#3}\par}
  \vspace{1pt}%
  {\setlength{\parindent}{0pt}#4\par}%
  \par\vspace{2pt}%
}

\NewDocumentCommand{\HypoSemanticStandardBox}{m m m +m}{%
  \HypoBox{#1}{#2}{#3}{hypobox/subtle}{#4}%
}

\NewDocumentCommand{\HypoSemanticNumberedBox}{m m m +m}{%
  \HypoBox{#1}{#2}{#3}{hypobox/card,fonttitle=\HypoQuestionTitleFont}{#4}%
}

\NewDocumentCommand{\HypoSemanticAnswerBox}{m m m +m}{%
  \HypoBox{#1}{#2}{#3}{hypobox/answer,fonttitle=\HypoAnswerTitleFont}{#4}%
}

\NewDocumentCommand{\HypoSemanticRubricBox}{m m m +m}{%
  \HypoBox{#1}{#2}{#3}{hypobox/rubric,fonttitle=\HypoRubricTitleFont}{#4}%
}

\NewDocumentCommand{\HypoSemanticBlock}{m +m}{%
  \HypoSemanticStandardBox{HypoSemantic}{summary}{#1}{#2}%
}

\newcounter{HypoQuestion}
\NewDocumentCommand{\HypoQuestionOutlineBox}{m +m}{%
  \HypoBox{HypoQuestion}{question}{#1}{%
    hypobox/question-plain,
    fonttitle=\HypoQuestionTitleFont,
    colbacktitle=HypoQuestionBack,
    coltitle=HypoQuestionFrame%
  }{#2}%
}

\NewDocumentCommand{\HypoQuestionTextBox}{m +m}{%
  \HypoTextQASection{HypoQuestion}{question}{#1}{#2}%
}

\NewDocumentCommand{\HypoQuestionBox}{m m +m}{%
  \ifHypo@ingroupedqa
    \HypoQASection{HypoQuestion}{question}{#1}{#3}%
  \else
    \ifstrequal{#2}{card}{%
      \HypoSemanticNumberedBox{HypoQuestion}{question}{#1}{#3}%
    }{%
      \ifstrequal{#2}{plain}{%
        \HypoQuestionTextBox{#1}{#3}%
      }{%
        \HypoQuestionOutlineBox{#1}{#3}%
      }%
    }%
  \fi
}

\NewDocumentEnvironment{HypoQuestion}{O{} O{} O{true} O{outline} +b}{%
  \ifstrequal{#3}{false}{%
    \HypoQuestionBox{\Hypo@ResolveTitle{#2}{Question}}{#4}{#5}%
  }{%
    \refstepcounter{HypoQuestion}%
    \if\relax\detokenize{#1}\relax\else\label{#1}\fi
    \ifstrequal{#4}{plain}{%
      \HypoQuestionBox{\Hypo@ResolvePrefixedTitle{#2}{Question~\theHypoQuestion}}{#4}{#5}%
    }{%
      \HypoQuestionBox{\Hypo@ResolveTitle{#2}{Question~\theHypoQuestion}}{#4}{#5}%
    }%
  }%
}{}

\NewDocumentEnvironment{HypoQA}{O{} O{grouped} +b}{%
  \HypoBox{HypoQuestion}{question}{\Hypo@ResolveTitle{#1}{Question Set}}{hypobox/qa,fonttitle=\HypoQuestionTitleFont}{%
    \Hypo@ingroupedqatrue
    #3%
    \Hypo@ingroupedqafalse
  }%
}{}

\NewDocumentEnvironment{HypoHint}{O{} O{} +b}{%
  \ifHypo@ingroupedqa
    \HypoQASection{HypoHint}{hint}{\Hypo@ResolveTitle{#1}{Hint}}{#3}%
  \else
    \ifstrequal{#2}{plain}{%
      \HypoTextQASection{HypoHint}{hint}{\Hypo@ResolveTitle{#1}{Hint}}{#3}%
    }{%
      \HypoSemanticStandardBox{HypoHint}{hint}{\Hypo@ResolveTitle{#1}{Hint}}{#3}%
    }%
  \fi
}{}

\NewDocumentEnvironment{HypoSolution}{O{} O{} +b}{%
  \HypoIfAnswerVisibleTF{%
    \ifHypo@ingroupedqa
      \HypoQASection{HypoSolution}{solution}{\Hypo@ResolveTitle{#1}{Solution}}{#3}%
    \else
      \ifstrequal{#2}{plain}{%
        \HypoTextQASection{HypoSolution}{solution}{\Hypo@ResolveTitle{#1}{Solution}}{#3}%
      }{%
        \HypoSemanticAnswerBox{HypoSolution}{solution}{\Hypo@ResolveTitle{#1}{Solution}}{#3}%
      }%
    \fi
  }{}%
}{}

\RenewDocumentEnvironment{HypoAnswer}{O{} O{} +b}{%
  \HypoIfAnswerVisibleTF{%
    \ifHypo@ingroupedqa
      \HypoQASection{HypoAnswer}{answer}{\Hypo@ResolveTitle{#1}{Answer}}{#3}%
    \else
      \ifstrequal{#2}{plain}{%
        \HypoTextQASection{HypoAnswer}{answer}{\Hypo@ResolveTitle{#1}{Answer}}{#3}%
      }{%
        \HypoSemanticAnswerBox{HypoAnswer}{answer}{\Hypo@ResolveTitle{#1}{Answer}}{#3}%
      }%
    \fi
  }{}%
}{}

\NewDocumentEnvironment{HypoObjective}{O{} +b}{%
  \HypoSemanticStandardBox{HypoSemantic}{objective}{\Hypo@ResolveTitle{#1}{Objective}}{#2}%
}{}

\NewDocumentEnvironment{HypoInfo}{O{} +b}{%
  \HypoSemanticStandardBox{HypoSemantic}{info}{\Hypo@ResolveTitle{#1}{Info}}{#2}%
}{}

\NewDocumentEnvironment{HypoTask}{O{} +b}{%
  \HypoSemanticStandardBox{HypoSemantic}{task}{\Hypo@ResolveTitle{#1}{Task}}{#2}%
}{}

\NewDocumentEnvironment{HypoRequirement}{O{} +b}{%
  \HypoSemanticStandardBox{HypoRequirement}{requirement}{\Hypo@ResolveTitle{#1}{Requirement}}{#2}%
}{}

\NewDocumentEnvironment{HypoDeliverable}{O{} +b}{%
  \HypoSemanticStandardBox{HypoSemantic}{deliverable}{\Hypo@ResolveTitle{#1}{Deliverable}}{#2}%
}{}

\NewDocumentEnvironment{HypoChecklist}{O{} +b}{%
  \HypoSemanticStandardBox{HypoSemantic}{checklist}{\Hypo@ResolveTitle{#1}{Checklist}}{#2}%
}{}

\NewDocumentEnvironment{HypoRubric}{O{} +b}{%
  \HypoSemanticRubricBox{HypoRubric}{rubric}{\Hypo@ResolveTitle{#1}{Rubric}}{#2}%
}{}
\makeatother
