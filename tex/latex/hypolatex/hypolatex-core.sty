\lstdefinestyle{HypoListingStyle}{
  basicstyle=\ttfamily\small\color{HypoInk},
  keywordstyle=\color{HypoAccent}\bfseries,
  commentstyle=\color{HypoMuted}\itshape,
  stringstyle=\color{HypoAccent},
  columns=fullflexible,
  keepspaces=true,
  breaklines=true,
  breakatwhitespace=false,
  showstringspaces=false,
  tabsize=2
}

\newtcblisting{HypoCodeBlock}[1][]{
  listing only,
  breakable,
  enhanced,
  colback=HypoNoteBack,
  colframe=HypoSemanticFrame,
  boxrule=0.35pt,
  arc=1mm,
  left=8pt,
  right=8pt,
  top=6pt,
  bottom=6pt,
  before skip=6pt,
  after skip=8pt,
  listing options={style=HypoListingStyle,#1}
}

\newtcblisting{HypoCodeCommand}[1][]{
  listing only,
  breakable,
  enhanced,
  center,
  width=0.88\linewidth,
  colback=HypoNoteBack,
  colframe=HypoSemanticFrame,
  boxrule=0.35pt,
  arc=1mm,
  left=9pt,
  right=9pt,
  top=5pt,
  bottom=5pt,
  before skip=6pt,
  after skip=8pt,
  listing options={style=HypoListingStyle,#1}
}

\makeatletter
% An `on line' tcbox cannot break across lines. Long inline code (common in
% narrow cheatsheet columns) would overflow the line, so fall back to plain
% accent-colored breakable text whenever the boxed content would eat most of
% the current line width.
\AtBeginDocument{%
  \let\Hypo@OriginalTexttt\texttt
  \newtcbox{\HypoInlineCode}{%
    on line,
    nobeforeafter,
    colback=HypoNoteBack,
    colframe=HypoSemanticFrame,
    coltext=HypoAccent,
    boxrule=0.25pt,
    arc=1pt,
    left=1.8pt,
    right=1.8pt,
    top=0.7pt,
    bottom=0.7pt,
    boxsep=0pt,
    tcbox raise base
  }%
  \newcommand{\Hypo@BreakableInlineCode}[1]{%
    {\color{HypoAccent}\ttfamily #1}%
  }%
  \RenewDocumentCommand{\texttt}{m}{%
    \begingroup
      % Measure with plain \ttfamily: the robust \texttt internals
      % (\check@icl lookahead) break inside \sbox.
      \sbox\z@{\ttfamily #1}%
      \ifdim\wd\z@>0.6\linewidth
        \Hypo@BreakableInlineCode{#1}%
      \else
        \HypoInlineCode{\Hypo@OriginalTexttt{#1}}%
      \fi
    \endgroup
  }%
}
\makeatother

