\Hypo@showanswersfalse

\newcommand{\HypoSetMetadata}[2]{%
  \ifcsdef{Hypo@metadata@#1}
    {\csgdef{Hypo@metadata@#1}{#2}}
    {\PackageWarning{hypolatex-core}{Unknown metadata key `#1'}}%
}

\newcommand{\HypoMetadata}[1]{%
  \ifcsdef{Hypo@metadata@#1}{\csuse{Hypo@metadata@#1}}{}%
}

\newcommand{\HypoIfMetadataTF}[3]{%
  \ifcsvoid{Hypo@metadata@#1}{#3}{#2}%
}

\newcommand{\HypoRef}[1]{Figure~\ref{#1}}

\newcommand{\HypoSetAnswerMode}[1]{%
  \renewcommand{\Hypo@answer@mode}{#1}%
  \ifstrequal{#1}{student}{%
    \Hypo@showanswersfalse
  }{%
    \ifstrequal{#1}{review}{%
      \Hypo@showanswerstrue
    }{%
      \ifstrequal{#1}{teacher}{%
        \Hypo@showanswerstrue
      }{%
        \PackageError{hypolatex-core}{Unknown answer mode `#1`}{Supported answer modes: student, review, teacher.}%
      }%
    }%
  }%
}

\newcommand{\HypoAnswerMode}{\Hypo@answer@mode}

\newcommand{\HypoIfAnswerVisibleTF}[2]{%
  \ifHypo@showanswers
    #1%
  \else
    #2%
  \fi
}

\NewDocumentEnvironment{HypoAnswer}{+b}{%
  \HypoIfAnswerVisibleTF{%
    \par
    #1%
    \par
  }{}%
}{}

\newcommand{\HypoFigureEx}[5]{%
  \begin{figure}[#5]
    \centering
    \IfFileExists{#2}{%
      \includegraphics[width=#4]{#2}%
    }{%
      \fbox{%
        \parbox[c][0.28\textheight][c]{0.82\linewidth}{%
          \centering
          \sffamily\small
          Figure asset unavailable\\[0.6em]
          \ttfamily\detokenize{#2}%
        }%
      }%
    }%
    \caption{#3}%
    \ifstrempty{#1}{}{\label{#1}}%
  \end{figure}%
}

\newcommand{\HypoFigure}[3]{%
  \HypoFigureEx{#1}{#2}{#3}{0.86\linewidth}{htbp}%
}
\makeatother
